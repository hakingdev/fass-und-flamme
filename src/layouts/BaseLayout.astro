---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  imageAlt?: string;
  robots?: string;
}

const {
  title,
  description,
  canonicalPath = "/",
  image = "/images/reservation-dinner-bier.jpg",
  imageAlt = "Fass & Flamme Steakhouse Bad Kissingen",
  robots,
} = Astro.props;

const canonical = new URL(canonicalPath, Astro.site ?? "https://fassflamme.de").toString();
const ogImage = new URL(image, Astro.site ?? "https://fassflamme.de").toString();
const robotsContent = robots ?? "index, follow, max-image-preview:large";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Fass & Flamme Steakhouse" />
    <meta name="application-name" content="Fass & Flamme" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#19100B" />
    <meta name="apple-mobile-web-app-title" content="Fass & Flamme" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content="Fass & Flamme Steakhouse" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700;800;900&family=Montserrat:wght@600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '2559333051174687');
      fbq('track', 'PageView');
    </script>
  </head>
  <body>
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=2559333051174687&ev=PageView&noscript=1"
        alt=""
      />
    </noscript>
    <slot />
    <div class="gastronaut-plugin-anchor" aria-hidden="true">
      <script
        is:inline
        type="text/javascript"
        src="https://api.gastronaut.ai/v02/reservations/plugin/fass-und-flamme-bad-kissingen/overlayWithBtn"
      ></script>
    </div>
    <script is:inline>
      const reservationUrl = "https://gastronaut.ai/reservations/fass-und-flamme-bad-kissingen";

      document.querySelectorAll(".site-header").forEach((header) => {
        const toggle = header.querySelector(".nav-toggle");
        const nav = header.querySelector("[data-site-nav]");
        if (!toggle || !nav) return;

        const syncStickyState = () => {
          header.classList.toggle("is-stuck", window.scrollY > 24);
        };

        syncStickyState();
        window.addEventListener("scroll", syncStickyState, { passive: true });

        toggle.addEventListener("click", () => {
          const isOpen = header.classList.toggle("is-open");
          toggle.setAttribute("aria-expanded", String(isOpen));
          toggle.setAttribute("aria-label", isOpen ? "Menü schließen" : "Menü öffnen");
        });

        nav.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            header.classList.remove("is-open");
            toggle.setAttribute("aria-expanded", "false");
            toggle.setAttribute("aria-label", "Menü öffnen");
          });
        });
      });

      document.querySelectorAll("[data-reservation-trigger]").forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.preventDefault();

          if (window.innerWidth <= 600) {
            window.open(reservationUrl, "_blank", "noopener");
            return;
          }

          const pluginButton = document.querySelector(".gastronaut-plugin-anchor button");
          if (pluginButton instanceof HTMLButtonElement) {
            pluginButton.click();
            return;
          }

          window.location.href = reservationUrl;
        });
      });
    </script>
  </body>
</html>
