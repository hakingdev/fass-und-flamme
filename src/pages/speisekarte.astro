      { name: "Double Dry Aged F&F Burger", description: "Cheddar, Bacon, BBQ-Sauce und Röstzwiebeln, 310/120/70 g", price: "25,00 €" },
      { name: "Shrimp Party Burger", description: "Mango-Chili-Salsa, Cheddar, Eisbergsalat und Rucola, 100/120/70 g", price: "21,00 €" },
      { name: "Lachsburger", description: "Mit Remoulade, 250/100/30 g", price: "20,00 €" },
      { name: "Veganer Burger", description: "Beyond Meat Patty und veganer Cheddar, 280/100/30 g", price: "20,00 €" },
    ],
  },
  {
    id: "fisch",
    title: "Fisch & Meeresfrüchte",
    note: "Vom Grill, mit Remoulade, Knoblauchsauce und Ofentomaten.",
