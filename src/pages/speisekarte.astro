    items: [
      { name: "Ribeye-Steak", description: "Sehr zart, stark marmoriert, min. 200 g", price: "17,00 € / 100 g" },
      { name: "New York Steak", description: "Zart, fein marmoriert, min. 200 g", price: "17,00 € / 100 g" },
      { name: "Filet-Mignon-Steak", description: "Sehr zart, besonders mager, min. 200 g", price: "18,00 € / 100 g" },
      { name: "Junges Kalbsentrecôte", description: "Sehr zart, fein marmoriert, min. 200 g", price: "17,00 € / 100 g" },
    ],
  },
  {
    id: "dry-aged",
    title: "Premium Dry Aged",
    note: "Mindestens 31 Tage gereift. Intensiver Geschmack, feine Marmorierung, Steakhouse-Charakter.",
    items: [
      { name: "Ribeye Dry Aged Steak", description: "Sehr zart, stark marmoriert, min. 200 g", price: "23,00 € / 100 g" },
      { name: "Ribeye Dry Aged Steak am Knochen", description: "Sehr zart, stark marmoriert, min. 400 g", price: "21,00 € / 100 g" },
      { name: "New-York-Steak Dry Aged", description: "Zart, fein marmoriert, min. 200 g", price: "23,00 € / 100 g" },
    ],
  },
  {
    id: "bbq",
    title: "BBQ & Grill",
    note: "Rippchen, Hähnchen und Grillplatten mit kräftigen Saucen.",
    items: [
      { name: "BBQ-Schweinerippchen", description: "300/50 g", price: "24,00 €" },
      { name: "BBQ-Rinderrippchen", description: "400/50 g", price: "28,00 €" },
      { name: "Kalbsrippchen mit Hot-Honey-Sauce", description: "Mit Hot-Honey-Sauce, BBQ-Dip und Tortilla, 450 g", price: "30,00 €" },
      { name: "Ganzes BBQ-Hähnchen", description: "Mit Salsa-Pesto-Sauce und Tortilla, 400 g", price: "20,00 €" },
      { name: "Sous-Vide Kalbfleisch", description: "Mit Pfeffersauce, 200 g", price: "25,00 €" },
    ],
  },
  {
    id: "burger",
    title: "Burgers",
    note: "Alle Burger mit Coleslaw und Kartoffel Dippers oder Pommes.",
