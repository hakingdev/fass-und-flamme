      { name: "Frittierte Tintenfischringe", description: "Mit Remoulade, 150/30 g", price: "12,00 €" },
      { name: "Buffalo Wings", description: "Pikante BBQ-Hähnchenflügel mit Dorblu-Sauce, 200/30 g", price: "10,00 €" },
      { name: "Vegane Grillwürstchen", description: "Mit Senf und Landbrot, 200/30 g", price: "10,00 €" },
      { name: "Frittierte Zwiebelringe", description: "Mit Ranch-Sauce, 150 g", price: "9,00 €" },
      { name: "Frittierte Peperoni", description: "Mit Käse, 180/30 g", price: "11,00 €" },
      { name: "Gemüseplatte", description: "Mit Tzatziki, 400/50 g", price: "14,00 €" },
      { name: "Platte mit luftgetrocknetem & geräuchertem Fleisch", description: "180 g", price: "20,00 €" },
      { name: "Käseplatte", description: "Cheddar, Brie, Pecorino Romano, Roquefort, Pesto-Käse, Rotweinkäse, 200 g", price: "18,00 €" },
    ],
  },
  {
    id: "salate",
    title: "Salate & Suppen",
    note: "Frische Teller, warme Suppen und Caesar-Extras vom Grill.",
    items: [
      { name: "Leichter saisonaler Salat", description: "200 g", price: "8,00 €" },
      { name: "Salat mit gegrilltem Käse", description: "200 g", price: "12,00 €" },
      { name: "Salat mit Avocado, Mango und Philadelphia-Käse", description: "200 g", price: "12,00 €" },
      { name: "Caesar Salat", description: "Mit Ciabatta-Croutons, 200 g", price: "11,00 €" },
      { name: "Caesar Extras", description: "Garnelen, Lachs oder gegrillte Hähnchenbrust", price: "+5,00 €" },
      { name: "Minestrone", description: "300 g", price: "9,00 €" },
