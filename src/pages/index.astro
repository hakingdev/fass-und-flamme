---
import BaseLayout from "../layouts/BaseLayout.astro";

const signatureDishes = [
  {
    title: "Ribeye Dry Aged Steak",
    description: "Mindestens 31 Tage gereift, sehr zart und stark marmoriert.",
    image: "/images/signature-ribeye.jpg",
  },
  {
    title: "New York Steak",
    description: "Zart, fein marmoriert und klassisch mit Wedges serviert.",
    image: "/images/signature-new-york-steak.jpg",
  },
  {
    title: "BBQ-Rinderrippchen",
    description: "Kräftig, rauchig und mit hausgemachten Saucen serviert.",
    image: "/images/signature-bbq-ribs.jpg",
  },
  {
    title: "Double Dry Aged F&F Burger",
    description: "Cheddar, Bacon, BBQ-Sauce und Röstzwiebeln.",
    image: "/images/signature-burger.jpg",
  },
  {
    title: "Gegrillte XL-Garnelen",
    description: "Mit Knoblauchsauce und Ofentomaten.",
    image: "/images/signature-shrimps.jpg",
  },
  {
    title: "Bierteller für Gruppen",
    description: "Pommes, Wings, Tintenfisch, Räucherkäse und Snacks zum Teilen.",
    image: "/images/signature-bierteller.jpg",
  },
];

const menuHighlights = [
  {
    title: "Ribeye Dry Aged Steak",
    description: "Sehr zart, stark marmoriert, mindestens 31 Tage gereift.",
    price: "ab 23,00 € / 100g",
  },
  {
    title: "New York Steak",
    description: "Zart, fein marmoriert und klassisch mit Wedges serviert.",
    price: "ab 17,00 € / 100g",
  },
  {
    title: "BBQ-Rinderrippchen",
    description: "Saftige Rippchen mit kräftigem BBQ-Charakter.",
    price: "28,00 €",
  },
  {
    title: "Double Dry Aged F&F Burger",
    description: "Mit Cheddar, Bacon, BBQ-Sauce und Röstzwiebeln.",
    price: "25,00 €",
  },
  {
    title: "Gegrillte XL-Garnelen",
    description: "Mit Knoblauchsauce und Ofentomaten.",
    price: "23,00 €",
  },
];

const reservationCards = [
  {
    title: "Steak Abend",
    price: "für 2-4 Personen",
    points: ["Dry Aged Cuts", "BBQ & hausgemachte Saucen", "Fassbier-Auswahl", "Tischreservierung empfohlen"],
    cta: "Tisch reservieren",
    image: "/images/reservation-steak-night.jpg",
  },
  {
    title: "Gruppenabend",
    price: "für 4-6 Personen",
    points: ["Grillplatte oder Steakplatte", "Bierteller zum Teilen", "Große Tische auf Anfrage", "Telefonische Abstimmung"],
    cta: "Gruppe anfragen",
    image: "/images/reservation-gruppenabend.jpg",
  },
  {
    title: "Dinner & Bier",
    price: "abends ab 17:00 Uhr",
    points: ["Burger, Steaks und BBQ", "Biere vom Fass", "Locker mit Freunden", "Montag und Dienstag Ruhetag"],
    cta: "Reservieren",
    image: "/images/reservation-dinner-bier.jpg",
  },
];

const hours = [
  ["Montag", "Ruhetag"],
  ["Dienstag", "Ruhetag"],
  ["Mittwoch", "17:00 - 22:00"],
  ["Donnerstag", "17:00 - 22:00"],
  ["Freitag", "17:00 - 22:00"],
  ["Samstag", "17:00 - 22:00"],
  ["Sonntag", "17:00 - 22:00"],
];

const schemaOpenDays = ["Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];

const restaurantSchema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: "Fass & Flamme Steakhouse",
  url: "https://fassflamme.de/",
  image: "https://fassflamme.de/images/reservation-dinner-bier.jpg",
  logo: "https://fassflamme.de/images/fass-flamme-logo-site.png",
  servesCuisine: ["Steakhouse", "BBQ", "Burger"],
  priceRange: "€€",
  telephone: "+4915251812634",
  email: "info@hotel-weisses-haus.com",
  hasMenu: "https://fassflamme.de/speisekarte/",
  acceptsReservations: true,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Kurhausstraße 14",
    postalCode: "97688",
    addressLocality: "Bad Kissingen",
    addressCountry: "DE",
  },
  openingHoursSpecification: schemaOpenDays.map((day) => ({
    "@type": "OpeningHoursSpecification",
    dayOfWeek: day,
    opens: "17:00",
    closes: "22:00",
  })),
};
---

<BaseLayout
  title="Fass & Flamme Bad Kissingen | Steakhouse & BBQ"
  description="Fass & Flamme Steakhouse in Bad Kissingen: Dry Aged Steaks, BBQ, Burger, Fisch, Bier vom Fass und Gruppenplatten. Jetzt Tisch reservieren."
>
  <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)}></script>

  <header class="site-header" aria-label="Hauptnavigation">
    <a class="brand" href="/" aria-label="Fass & Flamme Startseite">
      <img class="brand__logo brand__logo--default" src="/images/fass-flamme-logo-site.png" alt="Fass & Flamme Steakhouse" width="500" height="500" />
      <img class="brand__logo brand__logo--sticky" src="/images/fass-flamme-logo-original.svg" alt="" width="563" height="563" aria-hidden="true" />
    </a>
    <button class="nav-toggle" type="button" aria-label="Menü öffnen" aria-expanded="false" aria-controls="main-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav class="main-nav" id="main-nav" data-site-nav>
      <a href="/">Start</a>
      <a href="/galerie/">Galerie</a>
      <a href="/speisekarte/">Speisekarte</a>
      <a href="/reservierung/">Reservierung</a>
      <a href="/kontakt/">Kontakt</a>
    </nav>
  </header>

  <div class="wm-popup" data-wm-popup aria-hidden="true">
    <div class="wm-popup__backdrop" data-wm-popup-close></div>
    <section class="wm-popup__panel" role="dialog" aria-modal="true" aria-labelledby="wm-popup-title" aria-describedby="wm-popup-copy">
      <button class="wm-popup__close" type="button" aria-label="WM Hinweis schließen" data-wm-popup-close>
        <span></span>
        <span></span>
      </button>
      <div class="wm-popup__media" aria-hidden="true">
        <img src="/images/fass-flamme-logo-site.png" alt="" width="500" height="500" loading="eager" />
      </div>
      <div class="wm-popup__content">
        <p class="eyebrow">WM 2026 live</p>
        <h2 id="wm-popup-title">Deutschland anfeuern</h2>
        <p id="wm-popup-copy">
          Alle Gruppenspiele bei Fass &amp; Flamme: große Bildschirme, Fassbier, Steakhouse-Küche und Stimmung für die deutsche Elf.
        </p>
        <div class="wm-popup__actions">
          <a class="button button--primary" href="/wm-2026/">Zum Spielplan</a>
          <button class="button button--ghost" type="button" data-wm-popup-close>Später ansehen</button>
        </div>
      </div>
    </section>
  </div>

  <main>
    <section class="hero" aria-labelledby="hero-title">
      <img
        class="hero__image"
        src="/images/hero-steakhouse.png"
        alt="Gegrilltes Ribeye Steak im dunklen Steakhouse-Licht"
        fetchpriority="high"
      />
      <div class="hero__shade"></div>
      <div class="hero__content">
        <p class="eyebrow">Bad Kissingen Steakhouse</p>
        <h1 id="hero-title">Fass &amp; Flamme Steakhouse</h1>
        <p class="hero__copy">Dry Aged Steaks, BBQ vom Grill und frisch gezapftes Bier in Bad Kissingen.</p>
        <div class="hero__actions" aria-label="Hauptaktionen">
          <a class="button button--primary" href="https://gastronaut.ai/reservations/fass-und-flamme-bad-kissingen" data-reservation-trigger>Tisch reservieren</a>
          <a class="button button--ghost" href="/speisekarte/">Speisekarte ansehen</a>
        </div>
      </div>
    </section>

    <section class="section signature" aria-labelledby="signature-title">
      <div class="section__heading section__heading--left">
        <p class="eyebrow">Signature Dishes</p>
        <h2 id="signature-title">Steaks. Feuer. Fassbier.</h2>
      </div>
      <div class="signature__grid">
        {
          signatureDishes.map((dish) => (
            <article class="dish-card dish-card--image" style={`--dish-image: url("${dish.image}")`}>
              <div class="dish-card__photo" aria-hidden="true"></div>
              <h3>{dish.title}</h3>
              <p>{dish.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section story" aria-labelledby="story-title">
      <div class="story__panel story__panel--photo" aria-hidden="true"></div>
      <article class="story__panel story__panel--text">
        <p class="eyebrow">Unser Charakter</p>
        <h2 id="story-title">Ein Abend am Grill</h2>
        <p>
          Ein Abend bei Fass &amp; Flamme schmeckt nach Grill, Rauch, Kräuterbutter und frisch gezapftem Bier. Wir servieren kräftige
          Steakhouse-Küche für Paare, Freunde und große Runden.
        </p>
        <a class="button button--primary" href="/galerie/">Galerie ansehen</a>
      </article>
      <div class="story__panel story__panel--photo story__panel--photo-alt" aria-hidden="true"></div>
    </section>

    <section class="section menu-preview" aria-labelledby="menu-title">
      <div class="menu-preview__image" aria-hidden="true"></div>
      <div class="menu-preview__content">
        <p class="eyebrow">Speisekarte</p>
        <h2 id="menu-title">Main Menu</h2>
        <div class="menu-list">
          {
            menuHighlights.map((item) => (
              <article class="menu-item">
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.description}</p>
                </div>
                <strong>{item.price}</strong>
              </article>
            ))
          }
        </div>
        <a class="text-link" href="/speisekarte/">Komplette Speisekarte öffnen</a>
      </div>
    </section>

    <section class="section reservation" aria-labelledby="reservation-title">
      <div class="section__heading section__heading--left">
        <p class="eyebrow">Reservierung</p>
        <h2 id="reservation-title">Unvergessliche Abende mit Steak, BBQ und Fassbier</h2>
      </div>
      <div class="reservation__list">
        {
          reservationCards.map((card) => (
            <article class="reservation-card" style={`--reservation-image: url("${card.image}")`}>
              <div class="reservation-card__title">
                <h3>{card.title}</h3>
                <strong>{card.price}</strong>
                <a class="button button--primary" href="https://gastronaut.ai/reservations/fass-und-flamme-bad-kissingen" data-reservation-trigger>{card.cta}</a>
              </div>
              <ul>
                {card.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
              <div class="reservation-card__visual" aria-hidden="true"></div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section contact-strip" aria-labelledby="contact-title">
      <div class="contact-strip__photo" aria-hidden="true"></div>
      <div class="hours-card">
        <p class="eyebrow">Opening Hours</p>
        <h2>Öffnungszeiten</h2>
        <dl>
          {
            hours.map(([day, time]) => (
              <>
                <dt>{day}</dt>
                <dd>{time}</dd>
              </>
            ))
          }
        </dl>
      </div>
      <address class="contact-card">
        <p class="eyebrow">Adresse & Telefon</p>
        <h2 id="contact-title">Kontakt</h2>
          <span>Kurhausstraße 14, 97688 Bad Kissingen</span>
          <a href="tel:+4915251812634">01525 1812634</a>
          <a class="contact-card__email" href="mailto:info@hotel-weisses-haus.com">info@hotel-weisses-haus.com</a>
        </address>
    </section>
  </main>

  <footer class="site-footer">
    <div class="site-footer__links">
      <a href="/">Start</a>
      <a href="/speisekarte/">Speisekarte</a>
      <a href="/galerie/">Galerie</a>
    </div>
    <div class="site-footer__brand">
      <div class="site-footer__logo-wrap">
        <img class="site-footer__logo site-footer__logo--light" src="/images/fass-flamme-logo-site.png" alt="Fass & Flamme Steakhouse" width="500" height="500" loading="lazy" />
        <img class="site-footer__logo site-footer__logo--original" src="/images/fass-flamme-logo-original.svg" alt="" width="563" height="563" loading="lazy" aria-hidden="true" />
      </div>
      <p>Dry Aged Steaks, BBQ und Bier vom Fass in Bad Kissingen.</p>
    </div>
    <div class="site-footer__links site-footer__links--right">
      <a href="/reservierung/">Reservierung</a>
      <a href="/kontakt/">Kontakt</a>
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutz</a>
      <a href="tel:+4915251812634">Anrufen</a>
    </div>
  </footer>

  <script is:inline>
    const wmPopup = document.querySelector("[data-wm-popup]");
    if (wmPopup instanceof HTMLElement) {
      const firstLink = wmPopup.querySelector("a");

      const openPopup = () => {
        wmPopup.classList.add("is-visible");
        wmPopup.setAttribute("aria-hidden", "false");
        document.body.classList.add("is-wm-popup-open");
        if (firstLink instanceof HTMLElement) {
          firstLink.focus({ preventScroll: true });
        }
      };

      const closePopup = () => {
        wmPopup.classList.remove("is-visible");
        wmPopup.setAttribute("aria-hidden", "true");
        document.body.classList.remove("is-wm-popup-open");
      };

      wmPopup.addEventListener("click", (event) => {
        const target = event.target;
        if (target instanceof Element && target.closest("[data-wm-popup-close]")) {
          event.preventDefault();
          closePopup();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && wmPopup.classList.contains("is-visible")) {
          closePopup();
        }
      });

      window.setTimeout(openPopup, 650);
    }
  </script>
</BaseLayout>
